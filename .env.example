# AIBO 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
AIBO_HOST=127.0.0.1
AIBO_PORT=7437

# ── Logging ───────────────────────────────────────────────────
AIBO_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
AIBO_LOG_FILE=~/.aibo/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
AIBO_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# AIBO_CONFIG=~/.aibo/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# AIBO_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# AIBO_MAX_STEPS=20
